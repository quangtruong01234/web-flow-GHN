# ─────────────────────────────────────────────────────────────
# TryBuy GHN Logistics Web — .gitignore
# Keep generated, machine-local, and secret files out of git.
# The .ai/, .claude/, .agents/, AGENTS.md and handoff/ guidance
# files ARE meant to be committed (do not ignore them).
# ─────────────────────────────────────────────────────────────

# Dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Next.js build output
/.next/
/out/
/build
/dist

# TypeScript / build caches
*.tsbuildinfo
next-env.d.ts

# Testing / coverage
/coverage

# Playwright
/test-results
/playwright-report
/blob-report
/playwright/.cache

# Environment & secrets — never push these
# (GHN token, shop id, webhook secret, gateway URLs must stay out of git)
.env
.env.*
!.env.example

# Logs & debug output
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/

# OS junk
.DS_Store
Thumbs.db
desktop.ini

# Deployment
.vercel

# Local-only AI/agent settings (shared rules stay tracked, local overrides do not)
.claude/settings.local.json
.agents/**/local.*

# Certs / keys
*.pem
*.key
