# Copy to `.env.local` (git-ignored) and fill in.
# Only NEXT_PUBLIC_* vars are exposed to the browser.
# NEVER put GHN token / shop id / webhook secret here — those stay backend-only.

# --- Dev proxy (recommended) ---------------------------------------------------
# Leave NEXT_PUBLIC_API_URL EMPTY (or "/api") to route browser calls through the
# Next dev proxy (next.config.mjs). The browser hits this app's own origin at
# `/api/*` and Next forwards to the gateway below — session cookie stays
# first-party and no gateway CORS config is needed.
NEXT_PUBLIC_API_URL=/api

# Where the proxy forwards `/api/*` to (server-only, NOT exposed to the browser).
# Origin of the TryBuy Gateway. Default matches local dev.
API_PROXY_TARGET=http://localhost:3000

# --- Direct mode (alternative) -------------------------------------------------
# To bypass the proxy and call the gateway directly from the browser, set the
# absolute gateway URL instead (requires the gateway to allow this app's origin
# in CORS-with-credentials):
# NEXT_PUBLIC_API_URL=http://localhost:3000/api

# --- Demo mode (optional) ------------------------------------------------------
# Set to "true" to reveal the "Demo controls" GHN status picker on the shipment
# detail page, which drives the GHN status end-to-end via the backend demo
# endpoint (for sandbox orders GHN never advances past ready_to_pick). Pairs
# with the backend flag GHN_DEMO_ENDPOINTS_ENABLED. MUST stay off/absent in prod.
# NEXT_PUBLIC_GHN_DEMO_MODE=true
